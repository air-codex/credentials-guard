# credential-guard

# Uncomment these lines when using credential-guard in your project:
#
# Credentials folder (patterns, reports, keys, tokens)
#credentials/
#
# Bypass file
#credentials/bypass-scan
#
# Scan log
#credentials/scan-log.txt

#.env

# Banner assets (design files, not for production)
docs/assets/*.html
docs/assets/*.css
